# ── Copy this file to .env and fill in your values ──

# MongoDB Atlas (FREE) → mongodb.com → free cluster → Connect → Drivers
MONGO_URI=mongodb+srv://youruser:yourpassword@cluster0.mongodb.net/learnai

# Groq API Key (FREE) → console.groq.com → API Keys → Create Key
GROQ_API_KEY=your_groq_api_key_here

# JWT Secret → any random string
JWT_SECRET=your_random_secret_key_here_123

PORT=5000
